JIRA_BASE_URL=https://jira.example.com
JIRA_USERNAME=your.username
JIRA_PASSWORD=your-password

# Use this instead of username/password if your Jira supports bearer tokens.
# JIRA_TOKEN=your-token

# Optional non-secret defaults used when a project requires a category/custom field.
# JIRA_DEFAULT_CATEGORIES_JSON={"PROJECTKEY":"Category Name"}
